<script>
// ── Calculator ────────────────────────────────────────────────────
const MED_BASE={1:200,2:250,3:300,4:450,5:600,6:1000};
let timerInterval=null,timerTotalSec=0,timerEndTime=null,currentLang='en';

function setLang(lang,btn){
  currentLang=lang;document.body.className='lang-'+lang;
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');document.documentElement.lang=lang;
  updateSelectOptions();calculate();
}
function updateSelectOptions(){
  ['skinType','uvIndex','spf'].forEach(id=>{
    const sel=document.getElementById(id);if(!sel)return;
    Array.from(sel.options).forEach(opt=>{const t=opt.getAttribute('data-'+currentLang);if(t)opt.text=t;});
  });
}
function switchTab(name,el){
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');el.classList.add('active');
}
function calculate(){
  const skin=parseInt(document.getElementById('skinType').value);
  const uv=parseFloat(document.getElementById('uvIndex').value);
  const spfM=parseFloat(document.getElementById('spf').value);
  const mins=Math.round((MED_BASE[skin]/(uv*0.025*60))*spfM);
  const rc=document.getElementById('resultCard'),rt=document.getElementById('resultTime'),rl=document.getElementById('resultLabel');
  const labels={
    tooShort:{en:'< 5 min — seek shade immediately',zh:'< 5分钟——立即寻找阴凉',ko:'5분 미만 — 즉시 그늘로',ja:'5分未満 — すぐに日陰へ'},
    long:{en:'8+ hours — low burn risk today',zh:'8小时以上——今天晒伤风险低',ko:'8시간 이상 — 오늘 화상 위험 낮음',ja:'8時間以上 — 今日の日焼けリスク低'},
    est:{en:'Estimated safe time before burning',zh:'预计晒伤前的安全时间',ko:'화상 전 안전 추정 시간',ja:'日焼けまでの推定安全時間'}
  };
  const l=currentLang;
  if(mins<5){rt.textContent=labels.tooShort[l].split('—')[0].trim();rl.textContent=labels.tooShort[l].split('—')[1]?.trim()||'';rc.className='result-card danger';}
  else if(mins>480){rt.textContent=labels.long[l].split('—')[0].trim();rl.textContent=labels.long[l].split('—')[1]?.trim()||'';rc.className='result-card safe';}
  else{
    rt.textContent=mins>=60?(Math.floor(mins/60)+(mins%60?'h '+mins%60+'m':'h')):mins+' min';
    rl.textContent=labels.est[l];
    rc.className=mins<20?'result-card danger':mins<60?'result-card caution':'result-card safe';
  }
  document.getElementById('uvPin').style.left=Math.min((uv-1)/10*92,92)+'%';
  timerTotalSec=Math.min(Math.max(mins,1),480)*60;
  document.getElementById('ringNum').textContent=mins>480?'8+':mins>=60?Math.floor(mins/60)+(mins%60?':'+String(mins%60).padStart(2,'0'):''):mins;
  document.getElementById('ringUnit').textContent=({en:mins>=60?'hr':'min',zh:mins>=60?'小时':'分钟',ko:mins>=60?'시간':'분',ja:mins>=60?'時間':'分'})[currentLang]||'min';
  document.getElementById('ringProgress').style.strokeDashoffset=376;
  document.getElementById('ringProgress').style.stroke=mins<20?'#EF4444':mins<60?'#F59E0B':'#10B981';
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;resetTimerBtn();}
}
function resetTimerBtn(){
  document.getElementById('timerBtn').classList.remove('running');
  document.getElementById('timerMsg').textContent='';
  const l={en:'▶ Start timer',zh:'▶ 开始计时',ko:'▶ 타이머 시작',ja:'▶ タイマー開始'};
  document.getElementById('timerBtnText').innerHTML='<span data-lang="'+currentLang+'">'+l[currentLang]+'</span>';
}
function toggleTimer(){
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;document.getElementById('ringProgress').style.strokeDashoffset=376;resetTimerBtn();return;}
  document.getElementById('timerBtn').classList.add('running');
  const sl={en:'■ Stop',zh:'■ 停止',ko:'■ 중지',ja:'■ 停止'};
  document.getElementById('timerBtnText').innerHTML='<span>'+sl[currentLang]+'</span>';
  timerEndTime=Date.now()+timerTotalSec*1000;
  const ring=document.getElementById('ringProgress'),numEl=document.getElementById('ringNum'),unitEl=document.getElementById('ringUnit');
  timerInterval=setInterval(()=>{
    const remaining=Math.max(0,timerEndTime-Date.now());
    ring.style.strokeDashoffset=376*(remaining/(timerTotalSec*1000));
    const secs=Math.ceil(remaining/1000);
    if(secs>=3600){numEl.textContent=Math.ceil(secs/3600);unitEl.textContent=({en:'hr',zh:'小时',ko:'시간',ja:'時間'})[currentLang];}
    else if(secs>=60){numEl.textContent=Math.ceil(secs/60);unitEl.textContent=({en:'min',zh:'分钟',ko:'분',ja:'分'})[currentLang];}
    else{numEl.textContent=secs;unitEl.textContent=({en:'sec',zh:'秒',ko:'초',ja:'秒'})[currentLang];}
    if(remaining<=0){
      clearInterval(timerInterval);timerInterval=null;resetTimerBtn();ring.style.stroke='#EF4444';
      const dm={en:'⏰ Time to seek shade and reapply sunscreen!',zh:'⏰ 是时候寻找阴凉处并重新涂抹防晒霜了！',ko:'⏰ 그늘을 찾고 선크림을 다시 바를 시간입니다!',ja:'⏰ 日陰に入り日焼け止めを塗り直す時間です！'};
      document.getElementById('timerMsg').textContent=dm[currentLang];
    }
  },500);
}

// ── Sunscreen products ────────────────────────────────────────────
const DEFAULT_PRODUCTS=[
  {id:1,name:'Cancer Council Everyday SPF 50+',brand:'Cancer Council',spf:'SPF 50+',type:'Lotion',tags:['face','body','daily'],notes:'Lightweight, fragrance-free. Good all-rounder for patients on photosensitising medications.'},
  {id:2,name:'Invisible Zinc Tinted Day Wear SPF 50+',brand:'Invisible Zinc',spf:'SPF 50+',type:'Tinted',tags:['face','sensitive','tinted','daily'],notes:'Zinc oxide base. Ideal for patients with sensitive or reactive skin.'},
  {id:3,name:'Banana Boat Kids Sport SPF 50+',brand:'Banana Boat',spf:'SPF 50+',type:'Spray',tags:['body','kids','sport','water'],notes:'Water resistant 4 hours. Suitable for children on doxycycline for acne.'},
  {id:4,name:'La Roche-Posay Anthelios SPF 50+ Fluid',brand:'La Roche-Posay',spf:'SPF 50+',type:'Fluid',tags:['face','sensitive','daily'],notes:'Recommended for patients on retinoids or thiazide diuretics. Fragrance-free.'},
  {id:5,name:'Neutrogena Ultra Sheer SPF 50',brand:'Neutrogena',spf:'SPF 50',type:'Lotion',tags:['face','body','daily'],notes:'Non-greasy, absorbs quickly. Good for patients who find heavier sunscreens uncomfortable.'},
];
let products=JSON.parse(localStorage.getItem('sunscreen-products')||'null')||DEFAULT_PRODUCTS;
let editingId=null,activeFilter='all';
const tagLabels={face:'Face',body:'Body',sensitive:'Sensitive',kids:'Kids',sport:'Sport',water:'Water resistant',daily:'Daily use',tinted:'Tinted'};

function saveToStorage(){localStorage.setItem('sunscreen-products',JSON.stringify(products));}
function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

function renderProducts(){
  const grid=document.getElementById('productsGrid');
  const filtered=activeFilter==='all'?products:products.filter(p=>p.tags&&p.tags.includes(activeFilter));
  if(filtered.length===0){
    grid.innerHTML='<div class="empty-state"><span class="empty-icon">🧴</span><p>No products in this category yet.<br>Add one using the button below.</p></div>';
    return;
  }
  grid.innerHTML=filtered.map(p=>{
    const tagBadges=(p.tags||[]).map(t=>'<span class="badge badge-neutral">'+(tagLabels[t]||t)+'</span>').join('');
    return '<div class="product-card">'+
      '<div><div class="product-name">'+escHtml(p.name)+'</div>'+(p.brand?'<div class="product-brand">'+escHtml(p.brand)+'</div>':'')+
      '</div><div class="product-badges">'+
        (p.spf?'<span class="badge badge-spf">'+escHtml(p.spf)+'</span>':'')+
        (p.type?'<span class="badge badge-type">'+escHtml(p.type)+'</span>':'')+
        tagBadges+
      '</div>'+
      (p.notes?'<div class="product-notes">'+escHtml(p.notes)+'</div>':'')+
      '<div class="product-actions">'+
        '<button class="btn-edit" onclick="openModal('+p.id+')">✏ Edit</button>'+
        '<button class="btn-delete" onclick="deleteProduct('+p.id+')">Delete</button>'+
      '</div></div>';
  }).join('');
}

function filterProducts(tag,btn){
  activeFilter=tag;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');renderProducts();
}
function togglePill(label){const cb=label.querySelector('input');cb.checked=!cb.checked;label.classList.toggle('checked',cb.checked);}

function openModal(id){
  editingId=id||null;
  ['f-name','f-brand','f-notes'].forEach(i=>document.getElementById(i).value='');
  ['f-spf','f-type'].forEach(i=>document.getElementById(i).value='');
  document.querySelectorAll('#f-tags input').forEach(cb=>{cb.checked=false;cb.parentElement.classList.remove('checked');});
  if(id){
    document.getElementById('modalTitle').textContent='Edit product';
    const p=products.find(x=>x.id===id);
    if(p){
      document.getElementById('f-name').value=p.name||'';
      document.getElementById('f-brand').value=p.brand||'';
      document.getElementById('f-notes').value=p.notes||'';
      document.getElementById('f-spf').value=p.spf||'';
      document.getElementById('f-type').value=p.type||'';
      (p.tags||[]).forEach(t=>{const cb=document.querySelector('#f-tags input[value="'+t+'"]');if(cb){cb.checked=true;cb.parentElement.classList.add('checked');}});
    }
  } else {
    document.getElementById('modalTitle').textContent='Add sunscreen product';
  }
  document.getElementById('modalOverlay').classList.add('open');
}
function closeModal(){document.getElementById('modalOverlay').classList.remove('open');editingId=null;}
function handleOverlayClick(e){if(e.target===document.getElementById('modalOverlay'))closeModal();}

function saveProduct(){
  const name=document.getElementById('f-name').value.trim();
  if(!name){document.getElementById('f-name').style.borderColor='#EF4444';document.getElementById('f-name').focus();return;}
  document.getElementById('f-name').style.borderColor='';
  const tags=Array.from(document.querySelectorAll('#f-tags input:checked')).map(cb=>cb.value);
  const data={name,brand:document.getElementById('f-brand').value.trim(),spf:document.getElementById('f-spf').value,type:document.getElementById('f-type').value,notes:document.getElementById('f-notes').value.trim(),tags};
  if(editingId){const idx=products.findIndex(p=>p.id===editingId);if(idx>-1)products[idx]={...products[idx],...data};}
  else{data.id=Date.now();products.push(data);}
  saveToStorage();renderProducts();closeModal();
}
function deleteProduct(id){
  if(!confirm('Remove this product from the list?'))return;
  products=products.filter(p=>p.id!==id);saveToStorage();renderProducts();
}

updateSelectOptions();calculate();renderProducts();
</script>
</body>
